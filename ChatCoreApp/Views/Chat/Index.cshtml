@{
    ViewData["Title"] = "Chat";
}

<div class="container mt-4">

    <h2 class="text-center mb-4 fw-bold">
        💬 Chat Dashboard
    </h2>

    <div class="row">

        <div class="col-lg-4">

            <!-- Create Group -->
            <div class="card shadow mb-4">

                <div class="card-header bg-primary text-white">
                    Create Group
                </div>

                <div class="card-body">

                    <input id="groupName"
                           class="form-control mb-3"
                           placeholder="Group Name" />

                    <button class="btn btn-primary w-100"
                            id="btnCreateGroup">

                        Create Group

                    </button>

                </div>

            </div>
            <!-- Delete Room -->

            <div class="card shadow mb-4">

                <div class="card-header bg-danger text-white">

                    Delete Room

                </div>

                <div class="card-body">

                    <select id="deleteRoom"
                            class="form-select mb-3">
                    </select>

                    <button class="btn btn-danger w-100"
                            id="btnDeleteRoom">

                        <i class="bi bi-trash"></i>

                        Delete Room

                    </button>

                </div>

            </div>

            <!-- Join Group -->
            <div class="card shadow mb-4">

                <div class="card-header bg-success text-white">

                    Join Group

                </div>

                <div class="card-body">

                    <select id="joinGroup"
                            class="form-select mb-3">
                    </select>

                    <button class="btn btn-success w-100"
                            id="btnJoinGroup">

                        Join

                    </button>

                </div>

            </div>

            <!-- Leave Group -->

            <div class="card shadow">

                <div class="card-header bg-danger text-white">

                    Leave Group

                </div>

                <div class="card-body">

                    <select id="leaveGroup"
                            class="form-select mb-3">
                    </select>

                    <button class="btn btn-danger w-100"
                            id="btnLeaveGroup">

                        Leave

                    </button>

                </div>

            </div>

        </div>

        <div class="col-lg-8">

            <!-- Public Message -->

            <div class="card shadow mb-4">

                <div class="card-header bg-info text-white">

                    Public Message

                </div>

                <div class="card-body">

                    <select id="room"
                            class="form-select mb-3">
                    </select>

                    <div class="input-group">

                        <input id="txtGroupMessage"
                               class="form-control"
                               placeholder="Type message..." />

                        <button class="btn btn-info"
                                id="btnSendGroup">

                            Send

                        </button>

                    </div>

                </div>

            </div>

            <!-- Private -->

            <div class="card shadow mb-4">

                <div class="card-header bg-secondary text-white">

                    Private Message

                </div>

                <div class="card-body">

                    <select id="users"
                            class="form-select mb-3">
                    </select>

                    <div class="input-group">

                        <input id="txtPrivateMessage"
                               class="form-control"
                               placeholder="Type message..." />

                        <button class="btn btn-dark"
                                id="btnPrivate">

                            Send

                        </button>

                    </div>

                </div>

            </div>

            <!-- Messages -->

            <div class="card shadow">

                <div class="card-header">

                    Messages

                </div>

                <div class="card-body"
                     style="height:400px;overflow-y:auto;">

                    <ul id="messages"
                        class="list-group">
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script>
        let con = new signalR.HubConnectionBuilder().withUrl("/MyChat").build();

        let allGroupsCache = [];
        let currentGroupsCache = [];

        function populateSelect(selectId, items, valueProp, textProp, defaultText) {
            const select = document.getElementById(selectId);
            select.innerHTML = "";
            if (defaultText) {
                const opt = document.createElement("option");
                opt.value = "";
                opt.textContent = defaultText;
                select.appendChild(opt);
            }
            items.forEach(item => {
                const opt = document.createElement("option");
                opt.value = item[valueProp];
                opt.textContent = item[textProp];
                select.appendChild(opt);
            });
        }

        function refreshGroupDropdowns() {
            // Groups the current user is in go to Delete Room, Leave Group, and Public Message select
            populateSelect("deleteRoom", currentGroupsCache, "chatId", "name", "-- Select Room to Delete --");
            populateSelect("leaveGroup", currentGroupsCache, "chatId", "name", "-- Select Room to Leave --");
            populateSelect("room", currentGroupsCache, "chatId", "name", "-- Select Room to Message --");

            // Groups the current user has NOT joined go to Join Group select
            const joinableGroups = allGroupsCache.filter(g => !currentGroupsCache.some(cg => cg.chatId === g.chatId));
            populateSelect("joinGroup", joinableGroups, "chatId", "name", "-- Select Room to Join --");
        }

        con.on("AllAvaliableGroups", groups => {
            console.log("AllAvaliableGroups:", groups);
            allGroupsCache = groups;
            refreshGroupDropdowns();
        });

        con.on("CurrentGroups", groups => {
            console.log("CurrentGroups:", groups);
            currentGroupsCache = groups;
            refreshGroupDropdowns();
        });

        con.on("AllUsers", users => {
            console.log("AllUsers:", users);
            populateSelect("users", users, "id", "userName", "-- Select User for Private Message --");
        });

        con.on("ReceiveGroupMessage", (sender, groupName, message) => {
            const ul = document.getElementById("messages");
            const li = document.createElement("li");
            li.className = "list-group-item d-flex justify-content-between align-items-center";
            li.innerHTML = `<div><span class="badge bg-primary me-2">${groupName}</span><strong>${sender}:</strong> ${message}</div><small class="text-muted">${new Date().toLocaleTimeString()}</small>`;
            ul.appendChild(li);
            ul.parentElement.scrollTop = ul.parentElement.scrollHeight;
        });

        con.on("ReceivePrivateMessage", (sender, receiverId, message) => {
            const ul = document.getElementById("messages");
            const li = document.createElement("li");
            li.className = "list-group-item list-group-item-info d-flex justify-content-between align-items-center";
            li.innerHTML = `<div><span class="badge bg-dark me-2">🔒 Private</span><strong>${sender}:</strong> ${message}</div><small class="text-muted">${new Date().toLocaleTimeString()}</small>`;
            ul.appendChild(li);
            ul.parentElement.scrollTop = ul.parentElement.scrollHeight;
        });

        document.getElementById("btnCreateGroup").addEventListener("click", () => {
            const nameInput = document.getElementById("groupName");
            const name = nameInput.value.trim();
            if (name) {
                con.invoke("CreateGroup", name)
                    .then(() => { nameInput.value = ""; })
                    .catch(err => console.error(err));
            }
        });

        document.getElementById("btnDeleteRoom").addEventListener("click", () => {
            const select = document.getElementById("deleteRoom");
            const chatId = parseInt(select.value);
            if (chatId) {
                con.invoke("DeleteGroup", chatId).catch(err => console.error(err));
            }
        });

        document.getElementById("btnJoinGroup").addEventListener("click", () => {
            const select = document.getElementById("joinGroup");
            const chatId = parseInt(select.value);
            if (chatId) {
                con.invoke("JoinGroup", chatId).catch(err => console.error(err));
            }
        });

        document.getElementById("btnLeaveGroup").addEventListener("click", () => {
            const select = document.getElementById("leaveGroup");
            const chatId = parseInt(select.value);
            if (chatId) {
                con.invoke("LeaveGroup", chatId).catch(err => console.error(err));
            }
        });

        document.getElementById("btnSendGroup").addEventListener("click", () => {
            const select = document.getElementById("room");
            const msgInput = document.getElementById("txtGroupMessage");
            const chatId = parseInt(select.value);
            const msg = msgInput.value.trim();
            if (chatId && msg) {
                con.invoke("SendGroupMessage", chatId, msg)
                    .then(() => { msgInput.value = ""; })
                    .catch(err => console.error(err));
            }
        });

        document.getElementById("btnPrivate").addEventListener("click", () => {
            const select = document.getElementById("users");
            const msgInput = document.getElementById("txtPrivateMessage");
            const userId = select.value;
            const msg = msgInput.value.trim();
            if (userId && msg) {
                con.invoke("SendPrivateMessage", userId, msg)
                    .then(() => { msgInput.value = ""; })
                    .catch(err => console.error(err));
            }
        });

        con.start()
            .then(() => console.log("Connected to SignalR hub."))
            .catch(err => console.error("Error connecting to SignalR hub:", err));
    </script>
}


